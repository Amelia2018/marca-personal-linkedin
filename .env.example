# CONFIGURACIÓN DE ACCESO A LINKEDIN API (MARCA PERSONAL)
# Token de acceso temporal o de larga duración de la API de LinkedIn
LINKEDIN_ACCESS_TOKEN="tu_token_de_acceso_aqui"
# URN del autor de LinkedIn (ej. urn:li:person:XXXXX)
LINKEDIN_AUTHOR_URN="urn:li:person:tu_urn_person_id_aqui"
# Entorno de ejecución: development o production
ENV=development

# CONFIGURACIÓN DE APIS EXTERNAS PARA EL COCKPIT (AHORRO DE TOKENS)
# Clave de API de OpenRouter para modelos de texto gratuitos (o de pago)
OPENROUTER_API_KEY="tu_api_key_de_openrouter_aqui"
# Clave de API de Groq para procesamiento ultrarápido
GROQ_API_KEY="tu_api_key_de_groq_aqui"
# Clave de API de Pexels para búsquedas de imágenes de stock
PEXELS_API_KEY="tu_api_key_de_pexels_aqui"
